flowchart TB

    %% ==========================================
    %% スタイル定義（未来的・硬派カラーマトリクス）
    %% ==========================================
    classDef user fill:#2b2b2b,stroke:#00e676,stroke-width:2px,color:#fff;


    %% ==========================================
    %% 1. 入力 ＆ 知覚エンジン（第2世代）
    %% ==========================================
    subgraph Input_Phase ["【知覚・翻訳フェーズ】"]
        User["ユーザープロンプト<br/>（例：『お腹痛くてもリモート...』）"]:::user
        Embedding["1次元テキストを<br/>高次元概念ベクトルへ翻訳"]:::perception
        Keyphrase["MiniCube 語義DNA抽出<br/>（確信度・キーフレーズ抽出）"]:::perception
    end

    User --> Embedding
    User --> Keyphrase

    %% ==========================================
    %% 2. KVキャッシュハブ ＆ 4層Role
    %% ==========================================
    subgraph KV_Cache_Hub ["【生命的メモリ領域：KVキャッシュハブ】"]
        direction TB
        subgraph Role_Layer ["4階層Role定義 ＆ 特権保護"]
            Identity["人格・役割：identity<br/>（α=1.0固定・GC対象外）"]:::hub
            Ethics["倫理・安全：ethics<br/>（α=1.0固定・GC対象外）"]:::hub
            Core["重力：core<br/>（デフラグで生成、代謝・GC対象）"]:::hub
            Topic["文脈：topic<br/>（対話で追加、代謝・GC対象）"]:::hub
        end
        Traceability["トレーサビリティ<br/>(parent_id / origin_id)"]:::hub
    end

    Embedding --> |"概念ベクトル空間"| Topic
    Keyphrase --> |"近傍クラスタリング用フィルタ"| Topic
    Role_Layer -.-> Traceability

    %% ==========================================
    %% 3. 相対評価 ＆ ハイブリッド精査エンジン
    %% ==========================================
    subgraph Search_Engine ["【相対評価 ＆ 7階調引力バケット分けフィルタリング】"]
        RoughSearch["【第一段階：粗探索】<br/>360^3ビン類似度算出"]:::evaluation
        MaxOffset["最大値（max_score）特定<br/>相対差分 diff = score - max_score"]:::evaluation
        
        subgraph Seven_Buckets ["7階調引力バケット選択"]
            B01["Bucket 0, 1<br/>（離れている / 引力 = 0）"]:::conflict
            B24["Bucket 2, 4<br/>（近いが低/高 / 引力 = 0.5）"]:::evaluation
            B3["Bucket 3<br/>（ほぼ等しい / 最優先 / 引力 = 1.0）"]:::evaluation
            B56["Bucket 5, 6<br/>（離れている / 引力 = 0）"]:::conflict
        end

        ExactSearch["【第二段階：生ベクトル精査】<br/>マクロ類似度 ＋ ミクロ語義DNA一致度<br/>（MiniCubeコサイン類似度 閾値:0.65）"]:::evaluation
    end

    Topic --> RoughSearch
    RoughSearch --> MaxOffset
    MaxOffset --> Seven_Buckets
    
    B01 --> |"ノイズとして早期除外"| Trash1["一時非表示"]
    B56 --> |"物理的乖離判定"| Trash1
    B24 --> |"優先候補ロード"| ExactSearch
    B3 --> |"最優先ロード"| ExactSearch

    %% ==========================================
    %% 4. 葛藤検知 ＆ 意思決定
    %% ==========================================
    subgraph Decision_Core ["【思考ループ ＆ 葛藤・調和エンジン】"]
        PhysicsConflict{"物理的葛藤検知<br/>最大方位角差（dist >= 0.3）"}:::conflict
        
        subgraph Harmony_Route ["調和（方針B）"]
            Integrate["部分回答の自然統合<br/>(integration_engine)"]:::loop
        end

        subgraph Conflict_Route ["葛藤・対立（方針A）"]
            Analyze["対立構造の整理 ＆ 選択肢提示<br/>(conflict_engine)"]:::conflict
            WhiteFlag["冷徹な白旗（保留の進言）<br/>『私の中で意見が割れました』"]:::conflict
        end
    end

    ExactSearch --> PhysicsConflict
    PhysicsConflict --> |"葛藤なし"| Integrate
    PhysicsConflict --> |"葛藤あり"| Analyze
    Analyze --> WhiteFlag
    
    Integrate --> Response["LLMシステムからの最終回答"]:::user
    WhiteFlag --> Response

    %% ==========================================
    %% 5. 代謝システム（非同期デフラグ ＆ 段階的GC）
    %% ==========================================
    subgraph Metabolism_System ["【非同期代謝：睡眠と忘却のプロセス】"]
        Trigger["セッションアイドル（5〜10分後）<br/>またはエコースコア閾値超過で非同期発火"]:::metabolism
        Clustering["局所クラスタリング<br/>（DBSCAN/階層的凝集）"]:::metabolism
        
        subgraph Defrag_Process ["デフラグ（再解釈と統合）"]
            PoemFilter{"ポエム禁止判定<br/>事実ベースの抽象化"}:::metabolism
            MakeCore["新Core（新Origin）生成<br/>(defrag_engine)"]:::metabolism
            Decay["旧Topicを代謝対象へ降格<br/>(replacement_closeness = 0.8)"]:::metabolism
        end

        subgraph Garbage_Collection ["段階的GC（マーク ＆ 忘却）"]
            PhaseA["フェーズA<br/>αチャンネル減少・検索優先度低下"]:::metabolism
            PhaseB["アーカイブ<br/>role='history'移行、量子化int3コールド化"]:::metabolism
            PhaseC["セキュア物理消去<br/>WORMに署名ログ残し完全消去"]:::metabolism
        end
    end

    Response --> |"セッションアンロード"| Trigger
    Trigger --> Clustering
    Clustering --> PoemFilter
    PoemFilter --> |"合格"| MakeCore
    MakeCore --> Decay
    Decay --> PhaseA
    PhaseA --> PhaseB
    PhaseB --> PhaseC
    PhaseC --> |"リソース解放"| Role_Layer

    %% ==========================================
    %% 6. 未来志向（デュアルエンジン ＆ STP）
    %% ==========================================
    subgraph Future_Vision ["【未来兵装：v4.0+ ロードマップ】"]
        DualEngine["デュアルエンジン構成<br/>第2世代（知覚） × 第3世代（純粋ベクトル思考）"]:::future
        STP["STP (Semantic Transfer Protocol)<br/>言語を介さない、生の感覚ベクトルの直接交換"]:::future
        SSSTP["SS-STP (Semantic Signature STP)<br/>空間座標署名を用いた、クラウドと物理エッジの超同期"]:::future
    end

    Traceability -.-> DualEngine
    PhaseC -.-> STP
    STP -.-> SSSTP

